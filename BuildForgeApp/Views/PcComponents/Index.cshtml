@model IEnumerable<BuildForgeApp.Models.PcComponent>

@{
    ViewData["Title"] = "Component Catalog"; // page title

    // lists passed from controller for dropdown filters
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var brands = ViewBag.Brands as List<string> ?? new List<string>();
}

<h1>Component Catalog</h1>

<div class="mb-3">
    <input id="catalogSearch" class="form-control" placeholder="Live search..." /> <!-- client-side live search -->
</div>

<form asp-action="Index" method="get" class="mb-4">
    <input type="hidden" name="buildId" value="@ViewBag.BuildId" /> <!-- keeps current build context -->

    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="searchString" class="form-control" placeholder="Search..." /> <!-- server-side search -->
        </div>

        <div class="col-md-3">
            <select name="category" class="form-select"> <!-- category filter -->
                <option value="">All Categories</option>
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <select name="brand" class="form-select"> <!-- brand filter -->
                <option value="">All Brands</option>
                @foreach (var b in brands)
                {
                    <option value="@b">@b</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">Filter</button> <!-- submits filter form -->
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        No components found. <!-- shown if no results -->
    </div>
}
else
{
    <table class="table table-striped" id="componentTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Brand</th>
                <th>Type</th>
                <th>Price</th>
                <th></th> <!-- actions -->
            </tr>
        </thead>

        <tbody id="componentTableBody">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td> <!-- component name -->
                    <td>@item.Brand</td> <!-- brand -->
                    <td>@item.ComponentType</td> <!-- type -->
                    <td>@item.Price.ToString("C")</td> <!-- formatted price -->

                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                            Details
                        </a> <!-- view component details -->

                        @if (ViewBag.BuildId != null)
                        {
                            <form asp-action="AddToBuild" method="post" style="display:inline;">
                                @Html.AntiForgeryToken() <!-- security token -->

                                <input type="hidden" name="buildId" value="@ViewBag.BuildId" /> <!-- target build -->
                                <input type="hidden" name="componentId" value="@item.Id" /> <!-- selected component -->

                                <button type="submit" class="btn btn-sm btn-success">
                                    Add
                                </button> <!-- adds component to build -->
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", () => {
    const searchInput = document.getElementById("catalogSearch") // live search input
    const tableBody = document.getElementById("componentTableBody") // table body rows

    if (!searchInput || !tableBody) {
        return // exit if elements not found
    }

    let originalRows = Array.from(tableBody.querySelectorAll("tr")) // store all rows

    searchInput.addEventListener("input", () => {
        const text = searchInput.value.toLowerCase() // current search text

        originalRows.forEach(row => {
            const rowText = row.innerText.toLowerCase() // row content
            row.style.display = rowText.includes(text) ? "" : "none" // show/hide row
        })
    })
})
</script>
}
